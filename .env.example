# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
# Copy: cp .env.example .env
# Fill in your actual values
# NEVER commit .env to git
# =============================================================================

# App
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-groq-70b-8192-tool-use-preview
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# GitHub (Settings → Developer Settings → PAT → repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=MyFinalYearAutomationProject2022-2026
GITHUB_API_URL=https://api.github.com

# Slack (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb_your_token_here
SLACK_SIGNING_SECRET=your_signing_secret
DEFAULT_SLACK_CHANNEL=#automation-alert

# Jira (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_BASE_URL=https://inamrehman243.atlassian.net
JIRA_EMAIL=inamrehman243@gmail.com
JIRA_API_TOKEN=your_jira_token_here
JIRA_PROJECT_KEY=SCRUM
